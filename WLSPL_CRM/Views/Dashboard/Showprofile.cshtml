@model WLSPL_CRM_2.Models.RegisterUser
@{
    ViewData["Title"] = "Showprofile";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@* OLd Code
	<script>
	document.addEventListener("DOMContentLoaded", function () {
		const fileInput = document.getElementById('fileInput');
		const preview = document.getElementById('imagePreview');

		fileInput.addEventListener('change', function (event) {
			const file = event.target.files[0];

			if (file && file.type.startsWith('image/')) {
				const reader = new FileReader();

				reader.onload = function (e) {
					preview.src = e.target.result;
					preview.style.display = 'block';
				};

				reader.readAsDataURL(file);
			} else {
				preview.src = '#';
				preview.style.display = 'none';
			}
		});
	});

		function toggleNewPassword() {
			const passwordInput = document.getElementById("MainPassword");
			passwordInput.type = passwordInput.type === "password" ? "text" : "password";
		}

		function toggleConfirmPassword() {
			const passwordInput = document.getElementById("ConPassword");
			passwordInput.type = passwordInput.type === "password" ? "text" : "password";
		}
</script>
<div class="container mt-4">
	<div class="card">
		<div class="card-header text-white" style="background-color:#ff0000">
			<div class="row align-items-center">
				<div class="col-auto">
					<h1 class="card-title" style="font-size: 32px !important;">Edit Application </h1>
				</div>
				<div class="col-auto ms-auto">
					<a class="btn" style="border: 2px solid black;background: whitesmoke;color: red;"  asp-controller="Dashboard" asp-action="Index">
						<div class="d-flex align-items-center">
							<span class="nav-link-text"> Back </span>
						</div>
					</a>
				</div>
			</div>  
		</div>
		<div class="card-body">
			<form asp-controller="User" asp-action="Updateuser" method="post" enctype="multipart/form-data">
				@Html.AntiForgeryToken()
				<input type="hidden" asp-for="ID" />
				<div class="row">
					<div class="col-md-6">
						<!-- First Name -->
						<div class="form-group mb-3">
							<label asp-for="FirstName" class="form-label"> First Name</label>
							<input asp-for="FirstName" class="form-control" />
							<span asp-validation-for="FirstName" class="text-danger"></span>
						</div>
						<!-- Last Name -->
						<div class="form-group mb-3">
							<label asp-for="LastName" class="form-label"> Last Name</label>
							<input asp-for="LastName" class="form-control" />
							<span asp-validation-for="LastName" class="text-danger"></span>
						</div>
						<!-- Username -->
						<div class="form-group mb-3">
							<label asp-for="UserName" class="form-label">User Name</label>
							<input asp-for="UserName" class="form-control" />
							<span asp-validation-for="UserName" class="text-danger"></span>
						</div>
						@if (!string.IsNullOrEmpty(Model.ReportingID))
						{
							<div class="form-group mb-3">
								<label asp-for="ReportingFullName" class="form-label">Reporting Person</label>
								<input asp-for="ReportingFullName" class="form-control" readonly />
								<span asp-validation-for="ReportingFullName" class="text-danger"></span>
							</div>
						}

						@if (!string.IsNullOrEmpty(Model.SupervisorID))
						{

							<div class="form-group mb-3">
								<label asp-for="SupervisorFullName" class="form-label">Team Lead Name</label>
								<input asp-for="SupervisorFullName" class="form-control" readonly />
								<span asp-validation-for="SupervisorFullName" class="text-danger"></span>
							</div>
						}
						<!-- Password -->
						<div class="form-group mb-3">
							<label asp-for="Password" class="form-label"></label>
							<input asp-for="Password" type="password" id="MainPassword" class="form-control" value="@Model.Password" />
							<span asp-validation-for="Password" class="text-danger"></span>
							<div class="form-check mt-2" style="font-size: smaller;">
								<input type="checkbox" class="form-check-input" id="Password" onclick="toggleNewPassword()">
								<label class="form-check-label" for="showPassword">Show Password</label>
							</div>
						</div>
						<!-- Profile Photo Upload -->
						<div class="form-group mb-3">
							<label asp-for="File" class="form-label">Upload Profile Photo</label>
							<input asp-for="File" type="file" class="form-control" id="fileInput" accept="image/*" />
							<span asp-validation-for="File" class="text-danger"></span>
							<div class="row">
								@if (!string.IsNullOrEmpty(Model.PhotoPath))
								{
									<div class="col-md-6">
										<input type="hidden" asp-for="PhotoPath" />
										<div class="mt-2">
											<label>Current Profile Photo:</label><br />
											<img src="@Model.PhotoPath" alt="Profile Photo" style="max-width: 150px; max-height: 150px; border-radius: 5px;" />
										</div>
									</div>
								}
								<div class="col-md-6">
									<div class="mt-3">
										<img id="imagePreview" src="#" alt="Image Preview" style="display: none; max-width: 150px; max-height: 150px; border-radius: 5px;" />
									</div>
								</div>
							</div>
						</div>
					</div>

					<div class="col-md-6">
						<!-- Middle Name -->
						<div class="form-group mb-3">
							<label asp-for="MiddleName" class="form-label">Middle Name</label>
							<input asp-for="MiddleName" class="form-control" />
							<span asp-validation-for="MiddleName" class="text-danger"></span>
						</div>

						<!-- Email ID -->
						<div class="form-group mb-3">
							<label asp-for="EmailId" class="form-label">Email ID</label>
							<input asp-for="EmailId" class="form-control" />
							<span asp-validation-for="EmailId" class="text-danger"></span>
						</div>

						<!-- Mobile No -->
						<div class="form-group mb-3">
							<label asp-for="MobileNo" class="form-label">Mobile No</label>
							<input asp-for="MobileNo" class="form-control" />
							<span asp-validation-for="MobileNo" class="text-danger"></span>
						</div>
						@if (!string.IsNullOrEmpty(Model.ManagerID))
						{
							<div class="form-group mb-3">
								<label asp-for="ManagerFulltName" class="form-label">Manager Name</label>
								<input asp-for="ManagerFulltName" class="form-control" readonly />
								<span asp-validation-for="ManagerFulltName" class="text-danger"></span>
							</div>
							<div class="class=" form-group mb-3" style="margin-top: 113px;"></div>
						}

						<!-- Confirm Password -->
						<div class="form-group mb-3">
							<label asp-for="ConfirmPassword" class="form-label">Confirm Password</label>
							<input asp-for="ConfirmPassword" type="password" id="ConPassword" class="form-control" value="@Model.ConfirmPassword" />
							<span asp-validation-for="ConfirmPassword" class="text-danger"></span>
							<div class="form-check mt-2" style="font-size: smaller;">
								<input type="checkbox" class="form-check-input" id="showPassword1" onclick="toggleConfirmPassword()">
								<label class="form-check-label" for="showPassword1">Show Password</label>
							</div>
						</div>
					</div>
				</div>
				<div class="text-center mt-4">
					<button type="submit" class="btn btn-success px-5">Update</button>
				</div>
			</form>
		</div>
	</div>
</div>

@section Scripts {
	@{
		await Html.RenderPartialAsync("_ValidationScriptsPartial");
	}
} *@



<div class="row justify-content-center">
    <div class="col-xl-6 col-lg-8 col-md-10 col-12">

        <div class="card shadow-sm border-0">
            <div class="card-body p-4">

                <form asp-controller="User" asp-action="Updateuser" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="ID" />
					<input type="hidden" asp-for="PhotoPath" />
                    <!-- Profile Image + Camera Icon -->
                    <div class="text-center mb-4">
                        <div class="position-relative d-inline-block">
                            <img id="profileImage" src="@(Url.Content(Model.PhotoPath ?? "~/images/default-profile.png"))"
                                 alt="Profile"
                                 class="rounded-circle img-thumbnail"
                                 style="width: 120px; height: 120px; object-fit: cover;" />

                            <a href="javascript:void(0);" onclick="document.getElementById('fileInput').click();"
                               class="position-absolute bottom-0 end-0 bg-primary text-white rounded-circle border border-white shadow"
                               style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; font-size: 20px; cursor: pointer;">
                                <i class="fas fa-camera"></i>
                            </a>

                            <input type="file" asp-for="File" id="fileInput" accept="image/*" style="display: none;" />
                        </div>

                        <div id="fileNameDisplay" class="mt-2 text-muted small"></div>
                    </div>

                    <div class="row g-3">
                        <div class="col-sm-6">
                            <label asp-for="FirstName" class="form-label">First Name</label>
                            <input asp-for="FirstName" class="form-control" placeholder="Enter first name" />
                            <span asp-validation-for="FirstName" class="text-danger"></span>
                        </div>

                        <div class="col-sm-6">
                            <label asp-for="LastName" class="form-label">Last Name</label>
                            <input asp-for="LastName" class="form-control" placeholder="Enter last name" />
                            <span asp-validation-for="LastName" class="text-danger"></span>
                        </div>

                        <div class="col-sm-6">
                            <label asp-for="UserName" class="form-label">User Name</label>
                            <input asp-for="UserName" class="form-control" placeholder="Enter user name" />
                            <span asp-validation-for="UserName" class="text-danger"></span>
                        </div>

                        <div class="col-sm-6">
                            <label asp-for="MiddleName" class="form-label">Middle Name</label>
                            <input asp-for="MiddleName" class="form-control" placeholder="Enter middle name" />
                            <span asp-validation-for="MiddleName" class="text-danger"></span>
                        </div>

                        <div class="col-sm-6">
                            <label asp-for="EmailId" class="form-label">Email ID</label>
                            <input asp-for="EmailId" class="form-control" placeholder="Enter email" />
                            <span asp-validation-for="EmailId" class="text-danger"></span>
                        </div>

                        <div class="col-sm-6">
                            <label asp-for="MobileNo" class="form-label">Mobile No</label>
                            <input asp-for="MobileNo" class="form-control" placeholder="Enter mobile number" />
                            <span asp-validation-for="MobileNo" class="text-danger"></span>
                        </div>

                        @if (!string.IsNullOrEmpty(Model.ReportingID))
                        {
                            <div class="col-12">
                                <label asp-for="ReportingFullName" class="form-label">Reporting Person</label>
                                <input asp-for="ReportingFullName" class="form-control" readonly />
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(Model.SupervisorID))
                        {
                            <div class="col-12">
                                <label asp-for="SupervisorFullName" class="form-label">Team Lead Name</label>
                                <input asp-for="SupervisorFullName" class="form-control" readonly />
                            </div>
                        }

                        <div class="col-sm-6">
                            <label asp-for="Password" class="form-label">Password</label>
                            <input asp-for="Password" type="password" id="MainPassword" class="form-control" placeholder="Enter password" />
                            <div class="form-check mt-1">
                                <input type="checkbox" class="form-check-input" id="PasswordToggle" onclick="toggleNewPassword()" />
                                <label class="form-check-label" for="PasswordToggle">Show Password</label>
                            </div>
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>

                        <div class="col-sm-6">
                            <label asp-for="ConfirmPassword" class="form-label">Confirm Password</label>
                            <input asp-for="ConfirmPassword" type="password" id="ConPassword" class="form-control" placeholder="Confirm password" />
                            <div class="form-check mt-1">
                                <input type="checkbox" class="form-check-input" id="ConfirmPasswordToggle" onclick="toggleConfirmPassword()" />
                                <label class="form-check-label" for="ConfirmPasswordToggle">Show Password</label>
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>

                        <div class="col-12 text-center">
                            <label>New Photo Preview</label><br />
                            <img id="imagePreview" src="#" alt="Preview" class="img-thumbnail mt-2" style="display: none; max-width: 150px; max-height: 150px;" />
                        </div>
                    </div>

                    <div class="text-center mt-4">
                        <button type="submit" class="btn btn-primary px-5">Update Profile</button>
                    </div>
                </form>

            </div>
        </div>

    </div>
</div>



@section Scripts {
    <script>
        function toggleNewPassword() {
            const passInput = document.getElementById('MainPassword');
            passInput.type = passInput.type === 'password' ? 'text' : 'password';
        }

        function toggleConfirmPassword() {
            const conPassInput = document.getElementById('ConPassword');
            conPassInput.type = conPassInput.type === 'password' ? 'text' : 'password';
        }

        document.getElementById('fileInput').addEventListener('change', function (event) {
            const input = event.target;
            const fileDisplay = document.getElementById('fileNameDisplay');

            if (input.files && input.files[0]) {
                const file = input.files[0];

                const reader = new FileReader();
                reader.onload = function (e) {
                    document.getElementById('profileImage').src = e.target.result;
                    document.getElementById('imagePreview').src = e.target.result;
                    document.getElementById('imagePreview').style.display = 'block';
                };
                reader.readAsDataURL(file);

                fileDisplay.textContent = `Selected file: ${file.name}`;
            } else {
                fileDisplay.textContent = "No file selected.";
            }
        });
    </script>
}



