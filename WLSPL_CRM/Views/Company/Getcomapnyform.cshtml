@using Newtonsoft.Json
@using WLSPL_CRM_2.Models
@model List<WLSPL_CRM_2.Models.Company>
@{
    ViewData["Title"] = "Getcomapnyform";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<!-- Include SweetAlert2 CSS and JS -->
<link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.6.9/dist/sweetalert2.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.6.9/dist/sweetalert2.min.js"></script>

<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header">
                <div class="row align-items-center">
                    <div class="col-auto">
                        <h4 class="card-title">Add Company </h4>
                    </div>
                    <div class="col-auto ms-auto">
                        <a class="btn btn-primary" asp-controller="Company" asp-action="GetList">
                            <div class="d-flex align-items-center">
                                <span class="nav-link-text"> Company List </span>
                            </div>
                        </a>
                    </div>
                </div>
            </div>
            <div class="card-body pt-0">

                @if (TempData["SuccessMessage"] != null)
                {
                    <script>
                        Swal.fire({
                            icon: 'success',
                            title: 'Success!',
                            text: '@TempData["SuccessMessage"]',
                            showConfirmButton: true
                        });
                    </script>
                }

                @if (ViewBag.company == null)
                {
                    <form method="post" asp-action="SubmitDeatils" id="formmain">
                        <div class="card mb-4" style="color:red">
                            <div class="card-body">
                                <!-- Basic Info Section -->
                                <div class="row mb-2">
                                    <div class="col-md-6">
                                        <label for="companyCode" class="form-label">Company code</label>
                                        <input class="form-control" type="text" name="CompanyCode" readonly value="@ViewBag.code" style="color: red;" />
                                        <small asp-validation-for="CompanyCode" class="text-danger"></small>
                                    </div>
                                    <!-- Register For Dropdown -->
                                    <div class="col-md-6">
                                        <label for="Registerfor" class="form-label">Register For</label>
                                        <select class="form-control" name="Registerfor" id="Registerfor" >
                                            <option value="" disabled selected>-- Register For --</option>
                                            <option value="WLS">WLS</option>
                                            <option value="WLSPL">WLSPL</option>
                                        </select>
                                        <small asp-validation-for="Registerfor" class="text-danger"></small>
                                    </div>
                                </div>

                                <!-- Company Name Section -->
                                <div class="row mb-2">
                                    <div class="col-md-6">
                                        <label for="CompanyName" class="form-label">Company Name</label>
                                        <input class="form-control" type="text" placeholder="Enter Customer Name" name="CompanyName" id="CompanyName" />
                                        <small asp-validation-for="CompanyName" class="text-danger"></small>
                                    </div>

                                    <div class="col-md-6">
                                        <label for="SupplyType" class="form-label">Type of Supply For E-Invoice</label>
                                        <select class="form-control" name="SupplyType" onchange="checkgsttype()" id="SupplyType">
                                            <option value="" disabled selected>-- Select Type of Supply --</option>
                                            <option value="B2B">B2B</option>
                                            <option value="B2C">B2C</option>
                                            <option value="SEZWOP">SEZWOP</option>
                                            <option value="EXPWOP">EXPWOP</option>
                                        </select>
                                        <small asp-validation-for="SupplyType" class="text-danger"></small>
                                    </div>
                                </div>


                                <div class="row mb-2">
                                    <div class="col-md-6">
                                        <label for="vendorCode" class="form-label">Vendor Code </label>
                                        <input class="form-control" type="text" placeholder="Enter Vendor Code" name="vendorCode" id="vendorCode" />
                                        <small asp-validation-for="vendorCode" class="text-danger"></small>
                                    </div>
                                    <div class="col-md-6" id="dvGSTNo">
                                        <label for="GSTNo" class="form-label">GST Number</label>
                                        <input class="form-control" type="text" placeholder="GST Number" name="GSTNo" id="GSTNo" onchange="checkissubmit()" />
                                        <small asp-validation-for="GSTNo" class="text-danger"></small>
                                        <a href="https://services.gst.gov.in/services/searchtp" target="_blank" class="btn btn-link">Search GST Number</a>
                                        <div id="gst-error" style="color: red; display: none;">Please enter a valid GST number.</div>
                                    </div>
                                </div>
                                <!-- GST Number Section -->
                                <div class="row mb-2">
                                    <div class="col-md-6">
                                        <label for="AreaNAme" class="form-label">Area Name</label>
                                        <input class="form-control" type="text" placeholder="Area Name" name="AreaNAme" id="AreaNAme" />
                                        <small asp-validation-for="AreaNAme" class="text-danger"></small>
                                    </div>
                                </div>

                                <!-- Billing and Shipping Address Sections -->
                                <div class="row mb-2">
                                    <div class="col-md-6">
                                        <label for="BillAddress" class="form-label">Billing Address</label>
                                        <textarea class="form-control" placeholder="Enter Billing Address" name="BillingAddress" id="BillingAddress" onchange="copyBillingToShipping()" maxlength="100"></textarea>
                                        <small asp-validation-for="BillAddress" class="text-danger"></small>
                                    </div>
                                    <div class="col-md-6">
                                        <label for="ShippAddress" class="form-label">Shipping Address</label>
                                        <textarea class="form-control" type="text" placeholder="Enter Shipping Address" name="ShippingAddress" id="ShippingAddress"></textarea>
                                        <small asp-validation-for="ShippAddress" class="text-danger"></small>
                                    </div>
                                </div>

                                <!-- Billing and Shipping Location Sections -->
                                <div class="row mb-2">
                                    <div class="col-md-6">
                                        <label for="BillLocation" class="form-label">Billing Location</label>
                                        <input class="form-control" type="text" placeholder="Enter Billing Location" name="BillLocation" id="BillLocation" onchange="copyBillingToShipping()" />
                                        <small asp-validation-for="BillLocation" class="text-danger"></small>
                                    </div>
                                    <div class="col-md-6">
                                        <label for="ShippLocation" class="form-label">Shipping Location</label>
                                        <input class="form-control" type="text" placeholder="Enter Shipping Locations" name="ShippLocation" id="ShippLocation" />
                                        <small asp-validation-for="ShippLocation" class="text-danger"></small>
                                    </div>
                                </div>

                                <!-- Billing and Shipping Pincode Sections -->
                                <div class="row mb-2">
                                    <div class="col-md-6">
                                        <label for="BillingPincode" class="form-label">Billing Pincode</label>
                                        <input class="form-control" type="text" placeholder="Enter Billing Pincode" name="BillingPincode" id="BillingPincode" onchange="copyBillingToShipping()" />
                                        <small asp-validation-for="BillingPincode" class="text-danger"></small>
                                    </div>
                                    <div class="col-md-6">
                                        <label for="ShippingPincode" class="form-label">Shipping Pincode</label>
                                        <input class="form-control" type="text" placeholder="Enter Shipping Pincode" name="ShippingPincode" id="ShippingPincode" />
                                        <small asp-validation-for="ShippingPincode" class="text-danger"></small>
                                    </div>
                                </div>

                                <!-- Billing and Shipping State Code Sections -->
                                <div class="row mb-2">
                                    <div class="col-md-6">
                                        <label for="BillStateCode" class="form-label">Billing Statecode</label>
                                        <input class="form-control" type="text" placeholder="Enter Billing Statecode" name="BillStateCode" id="BillStateCode" onchange="copyBillingToShipping()" />
                                        <small asp-validation-for="BillStateCode" class="text-danger"></small>
                                    </div>
                                    <div class="col-md-6">
                                        <label for="ShippStateCode" class="form-label">Shipping State Code</label>
                                        <input class="form-control" type="text" placeholder="Enter Shipping State Code" name="ShippStateCode" id="ShippStateCode" />
                                        <small asp-validation-for="ShippStateCode" class="text-danger"></small>
                                    </div>
                                </div>

                                <!-- Contact Info Section -->
                                <div id="contactTable" style="display:none;">
                                    <h5>Additional Contacts</h5>
                                    <div id="contactBody"></div>
                                </div>

                                <!-- Add Contact Button -->
                                <div class="text-end mt-3">
                                    <button type="button" id="btnAddContactMain" class="btn btn-success">+ Add Contact</button>
                                </div>
                                <br />
                                <!-- Submit Button -->
                                <div class="d-flex justify-content-center">
                                    <button type="submit" class="btn btn-primary" id="btnSubmit">Submit</button>
                                </div>
                            </div>
                        </div>
                    </form>

                }
                else
                {
                    <form method="post" asp-action="UpdateDeatils" id="Updatemain">
                        <!-- Combined Card Section -->
                        <div class="card mb-4" style="color:red">
                            <div class="card-body">
                                <!-- Basic Info Section -->
                                <div class="row mb-2">
                                    <div class="col-md-6">
                                        <label for="companyCode" class="form-label">Comapny code</label>
                                        <input class="form-control" type="text" name="CompanyCode" readonly value="@ViewBag.company?.CompanyCode" style="color: red;" />
                                        <input type="hidden" id="ID" name="id" value="@ViewBag.company?.Id" />
                                        <small asp-validation-for="CompanyCode" class="text-danger"></small>
                                    </div>
                                    <div class="col-md-6">
                                        <label for="Registerfor" class="form-label">Register For</label>

                                        @Html.DropDownList(
                                        "Registerfor",
                                                                        new SelectList(ViewBag.RegisterForList, "Value", "Text", ViewBag.company?.Registerfor),
                                                                        "-- Register For --",
                                                                        new { @class = "form-control", id = "Registerfor" }
                                                                        )


                                </div>


                            </div>

                            <!-- Contact Details Section -->
                            <div class="row mb-2">
                                <div class="col-md-6">
                                    <label for="CompanyName" class="form-label">Comapny Name</label>
                                    <input class="form-control" type="text" placeholder="Enter Customer Name" name="CompanyName" id="CompanyName" value="@ViewBag.company?.CompanyName" />
                                    <small asp-validation-for="CompanyName" class="text-danger"></small>
                                </div>
                                <div class="col-md-6">
                                    <label for="SupplyType" class="form-label">Type of Supply For E-Invoice</label>

                                    @Html.DropDownList(
                                                                        "supplytype",
                                                                        new SelectList(ViewBag.SupplyTypes, "Value", "Text", ViewBag.company?.supplytype),
                                                                        "-- Select Type of Supply --",
                                                                        new { @class = "form-control", id = "SupplyType", onchange = "checkgsttype()" }
                                                                        )
                                    <small asp-validation-for="SupplyType" class="text-danger"></small>
                                </div>
                            </div>

                            <div class="row mb-2">
                                <div class="col-md-6">
                                    <label for="vendorCode" class="form-label">Vendor Code </label>
                                    <input class="form-control" type="text" placeholder="Enter Vendor Code" name="vendorCode" id="vendorCode" value="@ViewBag.company?.vendorCode" />
                                    <small asp-validation-for="vendorCode" class="text-danger"></small>
                                </div>
                                <div class="col-md-6" id="dvGSTNo">
                                    <label for="GSTNo" class="form-label">GST Number</label>
                                    <input class="form-control" type="text" placeholder="GST Number" name="GSTNo" id="GSTNo" onchange="checkissubmit()" value="@ViewBag.company?.GSTNo" />
                                    <small asp-validation-for="GSTNo" class="text-danger"></small>
                                    <a href="https://services.gst.gov.in/services/searchtp" target="_blank" class="btn btn-link">Search GST Number</a>
                                    <div id="gst-error" style="color: red; display: none;">Please enter a valid GST number.</div>
                                </div>
                            </div>

                            <div class="row mb-2">
                                <div class="col-md-6">
                                    <label for="AreaNAme" class="form-label">Area Name</label>
                                    <input class="form-control" type="text" placeholder="Area Name" name="AreaNAme" id="AreaNAme" value="@ViewBag.company?.AreaNAme" />
                                    <small asp-validation-for="AreaNAme" class="text-danger"></small>
                                </div>
                            </div>
                            <div class="row mb-2">
                                <div class="col-md-6">
                                    <label for="BillAddress" class="form-label">Billing Address</label>
                                    <textarea class="form-control" placeholder="Enter Billing Address" name="BillingAddress" id="BillingAddress">@ViewBag.company?.BillAddress</textarea>
                                    <small asp-validation-for="BillAddress" class="text-danger"></small>
                                </div>
                                <div class="col-md-6">
                                    <label for="ShippAddress" class="form-label">Shipping Address</label>
                                    <textarea class="form-control" placeholder="Enter Shipping Address" name="ShippingAddress" id="ShippingAddress">@ViewBag.company?.ShippAddress</textarea>
                                    <small asp-validation-for="ShippAddress" class="text-danger"></small>
                                </div>
                            </div>

                            <div class="row mb-2">
                                <div class="col-md-6">
                                    <label for="BillLocation" class="form-label">Billing Location</label>
                                    <input class="form-control" type="text" placeholder="Enter Billing Location" name="BillLocation" id="BillLocation" value="@ViewBag.company?.BillLocation" />
                                    <small asp-validation-for="BillLocation" class="text-danger"></small>
                                </div>
                                <div class="col-md-6">
                                    <label for="ShippLocation" class="form-label">Shipping Location</label>
                                    <input class="form-control" type="text" placeholder="Enter shipping Locations" name="ShippLocation" id="ShippLocation" value="@ViewBag.company?.ShippLocation" />
                                    <small asp-validation-for="ShippLocation" class="text-danger"></small>
                                </div>
                            </div>

                            <!-- Business Executive Info Section -->
                            <div class="row mb-2">
                                <div class="col-md-6">
                                    <label for="BillingPincode" class="form-label">Billing Pincode</label>
                                    <input class="form-control" type="text" placeholder="Enter Executive" name="BillingPincode" id="BillingPincode" value="@ViewBag.company?.BillingPincode" />
                                    <small asp-validation-for="BillingPincode" class="text-danger"></small>
                                </div>


                                <div class="col-md-6">
                                    <label for="shipping pincode" class="form-label">Shipping Pincode</label>
                                    <input class="form-control" type="text" placeholder="shipping pincode" name="ShippingPincode" id="ShippingPincode" value="@ViewBag.company?.ShippingPincode" />
                                    <small asp-validation-for="ShippingPincode" class="text-danger"></small>
                                </div>
                            </div>

                            <div class="row mb-2">
                                <div class="col-md-6">
                                    <label for="BillStateCode" class="form-label">Billing Statecode</label>
                                    <input class="form-control" type="text" placeholder="Enter Billing Statecode" name="BillStateCode" id="BillStateCode" value="@ViewBag.company?.BillStateCode" />
                                    <small asp-validation-for="BillStateCode" class="text-danger"></small>
                                </div>
                                <div class="col-md-6">
                                    <label for="ShippStateCode" class="form-label">Shipping State Code</label>
                                    <input class="form-control" type="text" placeholder="Enter Shipping state code" name="ShippStateCode" id="ShippStateCode" value="@ViewBag.company?.ShippStateCode" />
                                    <small asp-validation-for="ShippStateCode" class="text-danger"></small>
                                </div>
                            </div>


                            <div id="contactTable" style="display:none;">
                                <h5>Additional Contacts</h5>
                                <div id="contactBody"></div>
                            </div>

                            <!-- Add Contact Button -->
                            <div class="text-end mt-3">
                                <button type="button" id="btnAddContactMain" class="btn btn-success">+ Add Contact</button>
                            </div>
                        </div>
                    </div>
                    <br />
                    <!-- Submit Button -->
                    <div class="d-flex justify-content-center">
                        <button type="submit" class="btn btn-primary" id="btnUpdate">Update</button>
                    </div>
                </form>
                                }

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script type="text/javascript">
            window.onload = function() {
            checkgsttype();
        };
        function checkgsttype() {
            var selectedType = document.getElementById("SupplyType").value;
            var gstElement = document.getElementById("dvGSTNo");

            if (gstElement) {
                if (selectedType === "EXPWOP" || selectedType === "SEZWOP") {
                    console.log("Hiding GSTNo element");
                    gstElement.style.display = "none";
                } else {
                    console.log("Showing GSTNo element");
                    gstElement.style.display = "block";
                }
            } else {
                console.error('GSTNo element not found');
            }
        }

    </script>
    <script>
        function checkissubmit() {
            debugger;
            var gstNo = document.getElementById("GSTNo").value;
            var company = document.getElementById("CompanyName").value;

            if (gstNo && gstNo.length === 15) {

                var stateCode = gstNo.substring(0, 2);
                document.getElementById("BillStateCode").value = stateCode;
            }

            console.log("GSTNo: ", gstNo);
            console.log("Company: ", company);

            if (gstNo === "" || company === "") {
                alert("GST Number and Company Name cannot be empty!");
                return false;
            }

            $.ajax({
                url: '@Url.Action("checkcompanyandGst", "Company")',
                type: 'POST',
                data: {
                    gstNo: gstNo,
                    companyName: company
                },
                success: function (response) {
                    if (response === "Valid") {

                    } else {
                        alert("Company Already Present");
                    }
                },
                error: function (xhr, status, error) {
                    alert("An error occurred: " + error);
                }
            });

        }

    </script>

    <script>
        const formMain = document.getElementById("formmain");
        if (formMain) {
            formMain.addEventListener("submit", function (event) {
                if (!checkvalidation()) {
                    event.preventDefault();
                }
            });
        }

        const updateMain = document.getElementById("Updatemain");
        if (updateMain) {
            updateMain.addEventListener("submit", function (event) {
                if (!checkvalidation()) {
                    event.preventDefault();
                }
            });
        }


        function checkvalidation() {
            debugger;
            var registerFor = document.getElementById("Registerfor");
            var supplyType = document.getElementById("SupplyType");
            var vendorCode = document.getElementById("vendorCode");
            var AreaNAme = document.getElementById('AreaNAme');
            var gstNo = document.getElementById("GSTNo");
            var company = document.getElementById("CompanyName");
            var BillingAddress = document.getElementById('BillingAddress');
            var BillingLocations = document.getElementById('BillLocation');
            var ShippingAddress = document.getElementById('ShippingAddress');
            var ShippLocation = document.getElementById('ShippLocation');
            var BillingPincode = document.getElementById('BillingPincode');
            var ShippingPincode = document.getElementById('ShippingPincode');
            var BillStateCode = document.getElementById('BillStateCode');
            var ShippStateCode = document.getElementById('ShippStateCode');

            const fields = [
                { field: registerFor, message: "Please select 'Register For'." },
                { field: company, message: "Company Name cannot be empty." },
                {
                    field: gstNo,
                    validate: function (value) {
                        if (registerFor.value === "WLSPL" && supplyType.value ==='B2C' || supplyType.value ==='B2B') {
                            if (!value || value.trim() === "") return "GST Number cannot be empty.";
                            const regex = /^[0-9]{2}[A-Z]{5}[0-9]{4}[A-Z]{1}[1-9A-Z]{1}Z[0-9A-Z]{1}$/;
                            if (!regex.test(value.trim())) return "GST Number is not in a valid format.";
                        }
                        return "";
                    }
                },
                { field: supplyType, message: "Please select 'Supply Type For'." },
                { field: vendorCode, message: "Vendor Code cannot be empty." },
                { field: AreaNAme, message: "Area Name cannot be empty." },
                { field: BillingAddress, message: "Billing Address cannot be empty." },
                { field: BillingLocations, message: "Billing Location cannot be empty." },
                { field: ShippingAddress, message: "Shipping Address cannot be empty." },
                { field: ShippLocation, message: "Shipping Location cannot be empty." },
                { field: BillingPincode, message: "Billing Pincode cannot be empty." },
                { field: ShippingPincode, message: "Shipping Pincode cannot be empty." },
                { field: BillStateCode, message: "Billing State Code cannot be empty." },
                { field: ShippStateCode, message: "Shipping State Code cannot be empty." },
            ];

            // Clear previous error styles/messages
            resetErrorStyles(fields.map(f => f.field));

            for (let item of fields) {
                if (!item.field) {
                    console.warn("Missing field in DOM:", item);
                    continue; // Skip if field not found
                }

                const value = item.field.value?.trim();
                let errorMessage = "";

                if (item.validate) {
                    errorMessage = item.validate(value);
                } else if (!value) {
                    errorMessage = item.message;
                }

                if (errorMessage) {
                    displayErrorMessage(item.field, errorMessage);
                    item.field.classList.add("is-invalid");
                    item.field.focus();
                    return false;
                }
            }

            return true;
        }

        function displayErrorMessage(element, errorMessage) {
            const errorSpan = document.createElement("span");
            errorSpan.className = "error-message text-danger";
            errorSpan.textContent = errorMessage;

            const parentDiv = element.closest(".col-md-6") || element.parentNode;

            if (parentDiv && !parentDiv.querySelector(".error-message")) {
                parentDiv.appendChild(errorSpan);
            }
        }

        function resetErrorStyles(elements) {
            elements.forEach(element => {
                if (!element) return;
                element.classList.remove("is-invalid");
                const errorSpan = element.parentNode.querySelector(".error-message");
                if (errorSpan) {
                    errorSpan.remove();
                }
            });
        }


    </script>

    <script>
        function copyBillingToShipping() {
            const billingAddress = document.querySelector('[name="BillingAddress"]').value;
            const billingLocation = document.getElementById("BillLocation").value;
            const billingPincode = document.querySelector('[name="BillingPincode"]').value;
            const billingStateCode = document.getElementById("BillStateCode").value;
            document.getElementById("ShippingAddress").value = billingAddress;
            document.getElementById("ShippLocation").value = billingLocation;
            document.querySelector('[name="ShippingPincode"]').value = billingPincode;
            document.querySelector('[name="ShippStateCode"]').value = billingStateCode;

        }
    </script>



    <script>
            document.addEventListener("DOMContentLoaded", function () {
                let contactIndex = 0;
                const contactTable = document.getElementById("contactTable");
                const contactBody = document.getElementById("contactBody");
                const addButton = document.getElementById("btnAddContactMain");

                function createContactRow(contact = {}) {
                    if(contactIndex < 5){
                         const name = contact.Name || "";
                            const mobile = contact.MobileNo || "";
                            const email = contact.EmailID || "";
                            const designation = contact.Designation || "";

                            const row = document.createElement("div");
                            row.className = "row mb-2";
                            row.innerHTML = `
                                <div class="col-md-3">
                                    <input type="text" class="form-control" name="Contacts[${contactIndex}].Name" placeholder="Name" value="${name}" />
                                </div>
                                <div class="col-md-3">
                                    <input type="text" class="form-control" name="Contacts[${contactIndex}].MobileNo" placeholder="Mobile" value="${mobile}" />
                                </div>
                                <div class="col-md-3">
                                    <input type="email" class="form-control" name="Contacts[${contactIndex}].EmailID" placeholder="Email" value="${email}" />
                                </div>
                                <div class="col-md-3">
                                    <input type="text" class="form-control" name="Contacts[${contactIndex}].Designation" placeholder="Designation" value="${designation}" />
                                </div>
                            `;

                            contactBody.appendChild(row);
                            contactIndex++;
                    }else{
                        alert("Only 5 contact details can be added");
                    }

                }

                // Safe serialization
                const existingContacts = @Html.Raw(JsonConvert.SerializeObject(
                                                                            (Model != null && Model.FirstOrDefault()?.Contacts != null) ? Model.FirstOrDefault()?.Contacts : new List<Company.ContactModel>()));

    if (existingContacts.length > 0) {
        contactTable.style.display = "block";
        existingContacts.forEach(contact => createContactRow(contact));
    }

                addButton.addEventListener("click", function () {
                    contactTable.style.display = "block";
                    createContactRow();
                });
            });
    </script>

}





